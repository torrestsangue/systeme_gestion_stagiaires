generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String       @id @default(uuid())
  email            String       @unique
  password         String
  nom              String
  prenom           String
  telephone        String?
  role             Role         @default(STAGIAIRE)
  actif            Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  codeExpiresAt    DateTime?
  company          String?
  is_verify        Boolean      @default(false)
  refreshToken     String?      @db.Text
  verificationCode String?
  photoUrl         String?
  auditLogs        AuditLog[]
  evaluations      Evaluation[] @relation("Evaluator")
  rapportsValides  Rapport[]    @relation("RapportValidator")
  stagiaire        Stagiaire?
  tachesCreees     Tache[]      @relation("TacheCreator")
}

model Stagiaire {
  id            String      @id @default(uuid())
  userId        String      @unique
  numeroDossier String      @unique
  domaine       String
  dateDebut     DateTime
  dateFin       DateTime
  tuteurId      String?
  cvUrl         String?
  motivationUrl String?
  photoUrl      String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  evaluation    Evaluation?
  paiements     Paiement[]
  presences     Presence[]
  rapports      Rapport[]
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  taches        Tache[]
}

model Inscription {
  id            String            @id @default(uuid())
  numeroDossier String            @unique
  nom           String
  prenom        String
  email         String
  telephone     String?
  domaine       String
  periode       String
  cvUrl         String?
  motivationUrl String?
  status        InscriptionStatus @default(RECUE)
  commentaire   String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model Tache {
  id          String        @id @default(uuid())
  titre       String
  description String?
  statut      TacheStatut   @default(A_FAIRE)
  priorite    PriorityLevel @default(MOYENNE)
  deadline    DateTime?
  stagiaireId String
  createurId  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createur    User          @relation("TacheCreator", fields: [createurId], references: [id])
  stagiaire   Stagiaire     @relation(fields: [stagiaireId], references: [id], onDelete: Cascade)

  @@index([createurId], map: "Tache_createurId_fkey")
  @@index([stagiaireId], map: "Tache_stagiaireId_fkey")
}

model Rapport {
  id             String    @id @default(uuid())
  date           DateTime  @default(now())
  activites      String
  difficultes    String?
  apprentissages String?
  valide         Boolean   @default(false)
  commentaire    String?
  validateurId   String?
  stagiaireId    String
  createdAt      DateTime  @default(now())
  stagiaire      Stagiaire @relation(fields: [stagiaireId], references: [id], onDelete: Cascade)
  validateur     User?     @relation("RapportValidator", fields: [validateurId], references: [id])

  @@index([stagiaireId], map: "Rapport_stagiaireId_fkey")
  @@index([validateurId], map: "Rapport_validateurId_fkey")
}

model PresenceSession {
  id        String     @id @default(uuid())
  token     String     @unique
  expiresAt DateTime
  createdAt DateTime   @default(now())
  presences Presence[]
}

model Presence {
  id          String           @id @default(uuid())
  stagiaireId String
  sessionId   String?
  statut      PresenceStatut   @default(PRESENT)
  ip          String?
  latitude    Float?
  longitude   Float?
  scannedAt   DateTime         @default(now())
  session     PresenceSession? @relation(fields: [sessionId], references: [id])
  stagiaire   Stagiaire        @relation(fields: [stagiaireId], references: [id], onDelete: Cascade)

  @@index([sessionId], map: "Presence_sessionId_fkey")
  @@index([stagiaireId], map: "Presence_stagiaireId_fkey")
}

model Paiement {
  id           String            @id @default(uuid())
  stagiaireId  String
  montant      Float
  devise       String            @default("EUR")
  statut       PaiementStatut    @default(PLANIFIE)
  datePrevue   DateTime
  datePaiement DateTime?
  reference    String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  stagiaire    Stagiaire         @relation(fields: [stagiaireId], references: [id], onDelete: Cascade)
  tranches     TranchePaiement[]

  @@index([stagiaireId], map: "Paiement_stagiaireId_fkey")
}

model TranchePaiement {
  id              String        @id @default(uuid())
  paiementId      String
  montant         Float
  methode         PaymentMethod @default(MOMO)
  telephonePayeur String?
  reference       String?
  statut          TrancheStatut @default(EN_ATTENTE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paiement        Paiement      @relation(fields: [paiementId], references: [id], onDelete: Cascade)

  @@index([paiementId], map: "TranchePaiement_paiementId_fkey")
}

model Evaluation {
  id               String    @id @default(uuid())
  stagiaireId      String    @unique
  evaluateurId     String
  ponctualite      Float
  rapports         Float
  taches           Float
  competences      Float
  comportement     Float
  noteFinale       Float
  mention          String
  commentaire      String?
  attestationUrl   String?
  attestationToken String?   @unique
  createdAt        DateTime  @default(now())
  evaluateur       User      @relation("Evaluator", fields: [evaluateurId], references: [id])
  stagiaire        Stagiaire @relation(fields: [stagiaireId], references: [id], onDelete: Cascade)

  @@index([evaluateurId], map: "Evaluation_evaluateurId_fkey")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  cible     String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId], map: "AuditLog_userId_fkey")
}

enum Role {
  SUPER_ADMIN
  ADMIN_RH
  TUTEUR
  STAGIAIRE
}

enum InscriptionStatus {
  RECUE
  EN_EXAMEN
  ACCEPTEE
  REFUSEE
}

enum TacheStatut {
  A_FAIRE
  EN_COURS
  EN_REVISION
  TERMINEE
}

enum PriorityLevel {
  BASSE
  MOYENNE
  HAUTE
  URGENTE
}

enum PresenceStatut {
  PRESENT
  RETARD
  ABSENT
  TELETRAVAIL
}

enum PaiementStatut {
  PLANIFIE
  PARTIEL
  PAYE
  LITIGE
}

enum PaymentMethod {
  MOMO
  ORANGE
  CARD
  CASH
}

enum TrancheStatut {
  EN_ATTENTE
  REUSSIT
  ECHOUE
}
